# Copy this file to .env for local development (vercel dev), and set the
# same variables in your Vercel project's Environment Variables settings
# for production. Nothing in this file needs code changes per client —
# just fill in each client's own values.

# Secret API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Inbox that receives contact form submissions
CONTACT_EMAIL=client@example.com

# Sender address — must be on a domain verified in Resend
# (Resend > Domains). Using an unverified domain will cause sends to fail.
FROM_EMAIL=noreply@clientdomain.com.au

# Optional: display name for the sender, e.g. "GlowingLeads Website"
FROM_NAME=

# Optional: used as a fallback for FROM_NAME and appended to the email
# subject line, e.g. "GlowingLeads"
SITE_NAME=
